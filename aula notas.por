programa {
  funcao inicio(){}
   
    real nota = 8.7
   
    se(nota=10){
      escreva("conceito A")
      
      }
    senao se(nota>9 e nota<10){
      escreva(" conceito B")
      }
    senao se(nota>8 e nota <9){
      escreva("conceito C")
     }
    senao se(nota>=7 e nota<8){
      escreva("conceito D")
     }
    senao {
        escreva("conceito E")
      }
}       

    

